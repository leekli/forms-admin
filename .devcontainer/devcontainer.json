{
  "name": "GOV.UK Forms Admin Development Environment",

  // Uses the standard, secure MS community base image for Ruby 3
  "image": "mcr.microsoft.com/devcontainers/ruby:3",

  // Features keep setup streamlined without forcing custom Dockerfiles
  "features": {
    "ghcr.io/devcontainers/features/node:2": {
      "version": "20",
      "installYarnUsingApt": false
    },
    "ghcr.io/itsmechlark/features/postgresql:1": {
      "version": "15"
    }
  },

  // Remove any stale Yarn apt source, then install native build dependencies for Ruby and PostgreSQL
  "updateContentCommand": "sudo find /etc/apt -maxdepth 2 -type f \\( -name '*yarn*' -o -name '*Yarn*' \\) -delete && sudo apt-get update && sudo apt-get install -y build-essential libpq-dev git",

  // Install Ruby and JS dependencies, then prepare the Rails database
  "postCreateCommand": "bundle install && npm install && ./bin/rails db:prepare",

  // Environment variables required by the app to connect instantly to the Postgres feature container
  "containerEnv": {
    "DATABASE_URL": "postgresql://postgres:postgres@localhost:5432/forms_admin_development",
    "RAILS_ENV": "development"
  },

  // Rails server/Foreman usually binds to 3000. Vite dev server default maps nicely or hot-reloads over it
  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "GOV.UK Forms Admin Web App",
      "onAutoForward": "openPreview"
    }
  },

  // Custom VS Code workspace settings and explicit extension mapping for a polished developer experience
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "/bin/bash"
          }
        },

        // Ruby Development & Linting Configuration
        "ruby.lsp.enabled": true,
        "ruby.lsp.formatter": "rubocop",
        "[ruby]": {
          "editor.defaultFormatter": "Shopify.ruby-lsp",
          "editor.formatOnSave": true
        },

        // JavaScript / CSS / markdown formatting in the repo
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.tabSize": 2
        },
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        },
        "[scss]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode"
        }
      },
      "extensions": [
        "Shopify.ruby-lsp",
        "misogi.ruby-rubocop",
        "kaiwood.endwise",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml",
        "eamodio.gitlens",
        "GitHub.vscode-pull-request-github",
        "ms-azuretools.vscode-docker",
        "vitest.explorer",
        "banyis.rspec-snippets",
        "test-explorer.vscode-test-explorer",
        "editorconfig.editorconfig",
        "donjayamanne.githistory",
        "yzhang.markdown-all-in-one"
      ]
    }
  },

  // Fall back to standard non-root workspace user for proper permission scoping
  "remoteUser": "vscode"
}
